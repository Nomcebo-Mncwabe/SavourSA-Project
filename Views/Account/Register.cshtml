@model SavourSA_Project.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>SavourSA | Create Your Account</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/Account.css" />
</head>
<body class="account-body">
    <div class="account-card">
        <div class="account-header">
            <div class="brand">🍲 <span>Savour<b>SA</b></span></div>
            <div class="header-right">
                <span>Already have an account?</span>
                @Html.ActionLink("Login", "Login", "Account", null, new { @class = "btn btn-green" })
            </div>
        </div>

        <div class="account-body-content single-col">
            <h1>Create Your Account</h1>
            <p class="subtitle">Join our community and share your love for South African recipes.</p>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { enctype = "multipart/form-data", id = "registerForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger", role = "alert" })

                <div class="form-grid">
                    <div class="form-group">
                        @Html.LabelFor(m => m.FirstName)
                        @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Enter your first name", autocomplete = "given-name" })
                        @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.LastName)
                        @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Enter your last name", autocomplete = "family-name" })
                        @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.UserName)
                        @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Choose a username", autocomplete = "username" })
                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Email)
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter your email", type = "email", autocomplete = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.PhoneNumber)
                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "Enter your phone number", autocomplete = "tel" })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Province)
                        @Html.DropDownListFor(m => m.Province, new SelectList(ViewBag.Provinces), "Select your province", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Province, "", new { @class = "field-error" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Password)
                        <div class="password-wrap">
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Create a password", id = "Password" })
                            <span class="toggle-eye" data-target="Password">👁</span>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.ConfirmPassword)
                        <div class="password-wrap">
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirm your password", id = "ConfirmPassword" })
                            <span class="toggle-eye" data-target="ConfirmPassword">👁</span>
                        </div>
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
                    </div>
                </div>

                <div class="strength-row">
                    <label>Password Strength</label>
                    <div class="strength-bar"><div id="strengthFill" class="strength-fill"></div></div>
                    <span id="strengthLabel" class="strength-label"></span>
                </div>

                <div class="checkbox-row">
                    @Html.CheckBoxFor(m => m.AcceptTerms, new { id = "AcceptTerms" })
                    <label for="AcceptTerms">I accept the <a href="/Home/Popia" target="_blank">POPIA Act</a> and <a href="/Home/Privacy" target="_blank">Privacy Policy</a></label>
                </div>
                @Html.ValidationMessageFor(m => m.AcceptTerms, "", new { @class = "field-error" })

                <div class="checkbox-row">
                    @Html.CheckBoxFor(m => m.SubscribeNewsletter, new { id = "SubscribeNewsletter" })
                    <label for="SubscribeNewsletter">I would like to receive recipe tips and newsletter updates</label>
                </div>

                <div class="upload-box">
                    <div class="upload-icon">📷</div>
                    <div>
                        <p>Add a profile picture (optional)</p>
                        <span class="hint">JPG or PNG. Max size 2MB.</span><br />
                        <label class="btn-outline file-btn">
                            Choose Image
                            @Html.TextBoxFor(m => m.ProfilePicture, new { type = "file", accept = ".jpg,.jpeg,.png", style = "display:none", id = "fileInput" })
                        </label>
                        <span id="fileName" class="hint"></span>
                        @Html.ValidationMessageFor(m => m.ProfilePicture, "", new { @class = "field-error" })
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="btn-primary-wide">Register</button>

                <div class="divider"><span>OR</span></div>

                <div class="social-row">
                    <button type="button" class="btn-social" onclick="socialSignup('Google')">
                        <svg width="18" height="18" viewBox="0 0 48 48" style="vertical-align:middle;margin-right:8px;">
                            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.5z" />
                            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 15.6 18.9 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 6.1 29.6 4 24 4 16.3 4 9.7 8.3 6.3 14.7z" />
                            <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.6-5.2l-6.3-5.3C29.4 35.4 26.8 36 24 36c-5.2 0-9.6-3.1-11.3-7.6l-6.5 5C9.6 39.6 16.3 44 24 44z" />
                            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.1 5.6l6.3 5.3C40.9 36.5 44 30.8 44 24c0-1.3-.1-2.7-.4-3.5z" />
                        </svg>
                        Sign up with Google
                    </button>
                    <button type="button" class="btn-social" onclick="socialSignup('Apple')">
                        <svg width="18" height="18" viewBox="0 0 384 512" style="vertical-align:middle;margin-right:8px;">
                            <path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
                        </svg>
                        Sign up with Apple
                    </button>
                </div>
            }
        </div>
    </div>

    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/Scripts/Account.js"></script>
</body>
</html>