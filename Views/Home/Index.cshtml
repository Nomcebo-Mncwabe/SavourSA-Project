@{
    ViewBag.Title = "Welcome to SavourSA";
}

<style>
    :root {
        --forest: #1B4332;
        --sage: #40734F;
        --eucalyptus: #8FA998;
        --cream: #FBF8F2;
        --amber: #D9A441;
        --charcoal: #22291F;
    }

    .sa-page {
        background-color: var(--cream);
        color: var(--charcoal);
        font-family: 'Inter', -apple-system, sans-serif;
        margin: -20px -15px 0;
    }

        .sa-page h1, .sa-page h2, .sa-page h3 {
            font-family: 'Fraunces', Georgia, serif;
        }

    /* ---------- HERO ---------- */
    .sa-hero {
        background: linear-gradient(160deg, var(--forest) 0%, #234a37 60%, var(--sage) 130%);
        padding: 70px 20px 90px;
        position: relative;
        overflow: hidden;
    }

    .sa-hero-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 50px;
        flex-wrap: wrap;
    }

    .sa-hero-copy {
        flex: 1 1 380px;
        color: #fff;
    }

    .sa-eyebrow {
        display: inline-block;
        font-size: 12px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--amber);
        border: 1px solid rgba(217,164,65,0.5);
        padding: 5px 12px;
        border-radius: 20px;
        margin-bottom: 20px;
    }

    .sa-hero h1 {
        font-size: 46px;
        font-weight: 600;
        line-height: 1.15;
        margin: 0 0 18px;
    }

    .sa-hero p.lead {
        font-size: 18px;
        color: #E7EFE9;
        max-width: 480px;
        line-height: 1.6;
        margin-bottom: 30px;
    }

    .sa-btn {
        display: inline-block;
        padding: 13px 26px;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        margin: 4px 8px 4px 0;
        transition: transform 0.15s ease;
    }

        .sa-btn:hover {
            transform: translateY(-2px);
            text-decoration: none;
        }

    .sa-btn-primary {
        background: var(--amber);
        color: var(--charcoal);
    }

        .sa-btn-primary:hover {
            background: #e8b559;
            color: var(--charcoal);
        }

    .sa-btn-ghost {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.5);
    }

        .sa-btn-ghost:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

    /* ---------- SIGNATURE: recipe card ---------- */
    .sa-card-wrap {
        flex: 1 1 300px;
        display: flex;
        justify-content: center;
    }

    .sa-recipe-card {
        background: #FFFDF7;
        color: var(--charcoal);
        width: 280px;
        padding: 28px 24px 32px;
        border-radius: 3px;
        transform: rotate(-4deg);
        box-shadow: 0 25px 50px rgba(0,0,0,0.35);
        position: relative;
        font-family: 'Fraunces', serif;
    }

        .sa-recipe-card::before {
            content: "";
            position: absolute;
            top: -14px;
            right: 24px;
            width: 34px;
            height: 34px;
            background: var(--amber);
            border-radius: 50%;
            box-shadow: 0 4px 8px rgba(0,0,0,0.25);
        }

        .sa-recipe-card .corner {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 0;
            height: 0;
            border-style: solid;
            border-width: 0 0 26px 26px;
            border-color: transparent transparent var(--eucalyptus) transparent;
        }

        .sa-recipe-card h4 {
            font-size: 21px;
            margin: 6px 0 4px;
            border-bottom: 1px dashed var(--eucalyptus);
            padding-bottom: 10px;
        }

        .sa-recipe-card .tag {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--sage);
            margin-bottom: 10px;
        }

        .sa-recipe-card ul {
            font-family: 'Inter', sans-serif;
            font-size: 13.5px;
            line-height: 1.9;
            padding-left: 18px;
            margin: 12px 0 0;
            color: #4a4a3f;
        }

    /* ---------- FEATURES ---------- */
    .sa-features {
        max-width: 1100px;
        margin: 0 auto;
        padding: 80px 20px 60px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 28px;
    }

    .sa-feature-card {
        padding: 34px 26px;
        border-radius: 10px;
        color: #fff;
    }

        .sa-feature-card:nth-child(1) {
            background: var(--forest);
        }

        .sa-feature-card:nth-child(2) {
            background: var(--sage);
        }

        .sa-feature-card:nth-child(3) {
            background: #5C7A5A;
        }

        .sa-feature-card h3 {
            font-size: 21px;
            margin: 0 0 10px;
            font-weight: 600;
        }

        .sa-feature-card p {
            font-size: 14.5px;
            line-height: 1.6;
            color: rgba(255,255,255,0.9);
            margin: 0;
        }

    .sa-feature-icon {
        font-size: 26px;
        margin-bottom: 14px;
        display: block;
    }

    /* ---------- GALLERY STRIP ---------- */
    .sa-gallery {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px 80px;
        display: grid;
        grid-template-columns: 1.3fr 1fr 1fr;
        gap: 16px;
    }

        .sa-gallery img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            border-radius: 10px;
            display: block;
            background: var(--eucalyptus);
        }

        .sa-gallery .tall {
            height: 260px;
        }

    /* ---------- CTA ---------- */
    .sa-cta {
        background: var(--forest);
        text-align: center;
        padding: 70px 20px;
        color: #fff;
    }

        .sa-cta h2 {
            font-size: 30px;
            margin-bottom: 12px;
        }

        .sa-cta p {
            color: #E7EFE9;
            margin-bottom: 26px;
        }

    @@media (max-width: 700px) {
        .sa-hero h1 {
            font-size: 32px;
        }

        .sa-gallery {
            grid-template-columns: 1fr;
        }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<div class="sa-page">

    <!-- Hero -->
    <div class="sa-hero">
        <div class="sa-hero-inner">
            <div class="sa-hero-copy">
                <span class="sa-eyebrow">Recipes, shared</span>
                <h1>Share the Flavours of South Africa</h1>
                <p class="lead">
                    Discover, cook, and share authentic South African recipes with a community of home cooks and food lovers.
                </p>
                <div>
                    @Html.ActionLink("Browse Recipes", "Menu", "Guest", null, new { @class = "sa-btn sa-btn-primary" })
                    @Html.ActionLink("Login", "Login", "Account", null, new { @class = "sa-btn sa-btn-ghost" })
                    @Html.ActionLink("Sign Up", "Register", "Account", null, new { @class = "sa-btn sa-btn-ghost" })
                </div>
            </div>
            <div class="sa-card-wrap">
                <div class="sa-recipe-card">
                    <span class="tag">Family Recipe</span>
                    <h4>Bobotie</h4>
                    <ul>
                        <li>500g mince beef</li>
                        <li>2 tbsp curry powder</li>
                        <li>Bread soaked in milk</li>
                        <li>Bay leaves, raisins</li>
                        <li>Golden egg topping</li>
                    </ul>
                    <div class="corner"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div class="sa-features">
        <div class="sa-feature-card">
            <span class="sa-feature-icon">📖</span>
            <h3>Discover Recipes</h3>
            <p>Explore a growing collection of authentic South African dishes shared by real home cooks.</p>
        </div>
        <div class="sa-feature-card">
            <span class="sa-feature-icon">✍️</span>
            <h3>Share Your Own</h3>
            <p>Create an account to post your favourite recipes and build your own recipe collection.</p>
        </div>
        <div class="sa-feature-card">
            <span class="sa-feature-icon">❤️</span>
            <h3>Save Favourites</h3>
            <p>Bookmark recipes you love and come back to them anytime.</p>
        </div>
    </div>

    <!-- Gallery strip -->
    <div class="sa-gallery">
        <img class="tall" src="~/Content/Images/Categories/braai.jpg" alt="South African braai spread" onerror="this.src='https://placehold.co/600x400/40734F/FBF8F2?text=braai.jpg'" />
        <img src="~/Content/Images/Recipes/bunnychow.jpg" alt="Bunny chow" onerror="this.src='https://placehold.co/400x400/1B4332/FBF8F2?text=bunnychow.jpg'" />
        <img src="~/Content/Images/Categories/traditional.jpg" alt="Traditional South African dish" onerror="this.src='https://placehold.co/400x400/8FA998/22291F?text=traditional.jpg'" />
    </div>

    <!-- CTA -->
    <div class="sa-cta">
        <h2>Ready to Get Cooking?</h2>
        <p>Browse recipes now — no sign-up required.</p>
        @Html.ActionLink("Browse Recipes as Guest", "Menu", "Guest", null, new { @class = "sa-btn sa-btn-primary" })
    </div>

</div>