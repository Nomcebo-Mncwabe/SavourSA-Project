@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid">

    <h2 class="mb-4 fw-bold">Dashboard Overview</h2>

    <div class="row">

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card shadow-sm border-0 stat-card">

                <div class="card-body">

                    <h6>Total Users</h6>

                    <h2>128</h2>

                    <small>Registered Members</small>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card shadow-sm border-0 stat-card">

                <div class="card-body">

                    <h6>Total Recipes</h6>

                    <h2>347</h2>

                    <small>Recipes Uploaded</small>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card shadow-sm border-0 stat-card">

                <div class="card-body">

                    <h6>Categories</h6>

                    <h2>15</h2>

                    <small>Available Cuisines</small>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6 mb-4">

            <div class="card shadow-sm border-0 stat-card">

                <div class="card-body">

                    <h6>Comments</h6>

                    <h2>582</h2>

                    <small>Community Comments</small>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-lg-7">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white">

                    <h5>Recent Activity</h5>

                </div>

                <div class="card-body">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">
                            👤 John registered a new account
                        </li>

                        <li class="list-group-item">
                            🍲 New recipe added: Cape Malay Curry
                        </li>

                        <li class="list-group-item">
                            ❤️ Recipe added to favourites
                        </li>

                        <li class="list-group-item">
                            💬 New comment on Bunny Chow
                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <div class="col-lg-5">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white">

                    <h5>Quick Actions</h5>

                </div>

                <div class="card-body d-grid gap-2">

                    <button class="btn btn-success">
                        Manage Recipes
                    </button>

                    <button class="btn btn-success">
                        Manage Users
                    </button>

                    <button class="btn btn-success">
                        Manage Categories
                    </button>

                    <button class="btn btn-success">
                        View Reports
                    </button>

                </div>

            </div>

        </div>

    </div>

    <br />

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">

            <h5>Latest Recipes</h5>

        </div>

        <table class="table table-hover">

            <thead>

                <tr>

                    <th>Recipe</th>

                    <th>Author</th>

                    <th>Category</th>

                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                <tr>

                    <td>Umngqusho</td>

                    <td>Nomcebo</td>

                    <td>Xhosa</td>

                    <td><span class="badge bg-success">Active</span></td>

                </tr>

                <tr>

                    <td>Bunny Chow</td>

                    <td>Sarah</td>

                    <td>Indian SA</td>

                    <td><span class="badge bg-success">Active</span></td>

                </tr>

                <tr>

                    <td>Melktert</td>

                    <td>Peter</td>

                    <td>Dessert</td>

                    <td><span class="badge bg-warning">Pending</span></td>

                </tr>

            </tbody>

        </table>

    </div>

</div>