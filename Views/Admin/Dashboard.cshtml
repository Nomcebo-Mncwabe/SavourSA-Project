@model SavourSA_Project.Models.ViewModels.DashboardViewModel

@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="welcome-banner">

    <div class="row align-items-center">

        <div class="col-md-8">

            <h2>Welcome back, Administrator 👋</h2>

            <p>
                Manage recipes, categories, users and community activity from one beautiful dashboard.
            </p>

        </div>

        <div class="col-md-4 text-end">

            <i class="fas fa-seedling fa-5x"></i>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card users">

            <div>

                <h5>Total Members</h5>

                <h2>@Model.TotalUsers</h2>

            </div>

            <i class="fas fa-users fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card recipes">

            <div>

                <h5>Total Recipes</h5>

                <h2>@Model.TotalRecipes</h2>

            </div>

            <i class="fas fa-utensils fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card categories">

            <div>

                <h5>Categories</h5>

                <h2>@Model.TotalCategories</h2>

            </div>

            <i class="fas fa-layer-group fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card comments">

            <div>

                <h5>Comments</h5>

                <h2>@Model.TotalComments</h2>

            </div>

            <i class="fas fa-comments fa-3x"></i>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-lg-8">

        <div class="card">

            <div class="card-header">

                <h4>Recipe Upload Analytics</h4>

            </div>

            <div class="card-body">

                <div style="height:320px;
                            display:flex;
                            align-items:center;
                            justify-content:center;
                            flex-direction:column;">

                    <i class="fas fa-chart-line fa-5x text-success mb-3"></i>

                    <h4>Analytics Coming Soon</h4>

                    <p class="text-muted">

                        Chart.js will display recipe uploads here.

                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card">

            <div class="card-header">

                <h4>Quick Actions</h4>

            </div>

            <div class="card-body">

                <a href="@Url.Action("Recipes","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-utensils"></i>

                    Manage Recipes

                </a>

                <a href="@Url.Action("Categories","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-layer-group"></i>

                    Manage Categories

                </a>

                <a href="@Url.Action("Users","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-users"></i>

                    Manage Users

                </a>

                <a href="@Url.Action("Reports","Admin")"
                   class="btn btn-success w-100">

                    <i class="fas fa-chart-pie"></i>

                    View Reports

                </a>

            </div>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-lg-7">

        <div class="card">

            <div class="card-header">

                <h4>Latest Recipes</h4>

            </div>

            <div class="card-body">

                <table class="table">

                    <thead>

                        <tr>

                            <th>Recipe</th>

                            <th>Category</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>Umngqusho</td>

                            <td>Traditional</td>

                            <td>

                                <span class="status-active">

                                    Approved

                                </span>

                            </td>

                        </tr>

                        <tr>

                            <td>Bunny Chow</td>

                            <td>Street Food</td>

                            <td>

                                <span class="status-active">

                                    Approved

                                </span>

                            </td>

                        </tr>

                        <tr>

                            <td>Milk Tart</td>

                            <td>Desserts</td>

                            <td>

                                <span class="status-inactive">

                                    Pending

                                </span>

                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="col-lg-5">

        <div class="card">

            <div class="card-header">

                <h4>Recent Activity</h4>

            </div>

            <div class="card-body">

                <p>👤 Sarah registered.</p>

                <hr />

                <p>🍲 New recipe uploaded.</p>

                <hr />

                <p>💬 Comment reported.</p>

                <hr />

                <p>❤️ Recipe added to favourites.</p>

            </div>

        </div>

    </div>

</div>




