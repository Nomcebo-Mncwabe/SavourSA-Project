@model SavourSA_Project.Models.ViewModels.DashboardViewModel

@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="welcome-banner">

    <div class="row align-items-center">

        <div class="col-md-8">

            <h2>Welcome back, Administrator 👋</h2>

            <p>
                Manage recipes, categories, users and community activity from one dashboard.
            </p>

        </div>

        <div class="col-md-4 text-end">

            <i class="fas fa-seedling fa-5x"></i>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card users">

            <div>

                <h5>Total Members</h5>

                <h2>@Model.TotalUsers</h2>

            </div>

            <i class="fas fa-users fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card recipes">

            <div>

                <h5>Total Recipes</h5>

                <h2>@Model.TotalRecipes</h2>

            </div>

            <i class="fas fa-utensils fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card categories">

            <div>

                <h5>Categories</h5>

                <h2>@Model.TotalCategories</h2>

            </div>

            <i class="fas fa-layer-group fa-3x"></i>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card comments">

            <div>

                <h5>Favourites</h5>

                <h2>@Model.TotalFavourites</h2>

            </div>

            <i class="fas fa-heart fa-3x"></i>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-lg-8">

        <div class="card">

            <div class="card-header">

                <h4>Recipes by Category</h4>

            </div>

            <div class="card-body">

                <canvas id="recipeChart" height="120"></canvas>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card">

            <div class="card-header">

                <h4>Quick Actions</h4>

            </div>

            <div class="card-body">

                <a href="@Url.Action("Recipes","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-utensils"></i>

                    Manage Recipes

                </a>

                <a href="@Url.Action("Categories","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-layer-group"></i>

                    Manage Categories

                </a>

                <a href="@Url.Action("Users","Admin")"
                   class="btn btn-success w-100 mb-3">

                    <i class="fas fa-users"></i>

                    Manage Users

                </a>

                <a href="@Url.Action("Reports","Admin")"
                   class="btn btn-success w-100">

                    <i class="fas fa-chart-pie"></i>

                    View Reports

                </a>

            </div>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-lg-7">

        <div class="card">

            <div class="card-header">

                <h4>Latest Recipes</h4>

            </div>

            <div class="card-body">

                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Recipe</th>

                            <th>Category</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.RecentRecipes.Any())
                        {
                            foreach (var recipe in Model.RecentRecipes)
                            {
                                <tr>

                                    <td>@recipe.Title</td>

                                    <td>

                                        @(recipe.Category != null ? recipe.Category.Name : "No Category")

                                    </td>

                                    <td>

                                        <span class="status-active">

                                            Available

                                        </span>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="3" class="text-center">

                                    No recipes uploaded yet.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="col-lg-5">

        <div class="card">

            <div class="card-header">

                <h4>Category Summary</h4>

            </div>

            <div class="card-body">

                @if (Model.CategorySummary.Any())
                {
                    foreach (var item in Model.CategorySummary)
                    {
                        <p>

                            🍽 <strong>@item.CategoryName</strong>

                            (@item.RecipeCount recipes)

                        </p>

                        <hr />
                    }
                }
                else
                {
                    <p>No categories available.</p>
                }

            </div>

        </div>

    </div>

</div>

@section scripts{

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

const labels = [
@foreach (var item in Model.CategorySummary)
{
<text>'@item.CategoryName',</text>
}
];

const totals = [
@foreach (var item in Model.CategorySummary)
{
<text>@item.RecipeCount,</text>
}
];

const ctx = document.getElementById('recipeChart');

new Chart(ctx, {

    type: 'bar',

    data: {

        labels: labels,

        datasets: [{

            label: 'Recipes',

            data: totals,

            backgroundColor: [

                '#43A047',
                '#66BB6A',
                '#FFA726',
                '#26A69A',
                '#42A5F5',
                '#EF5350',
                '#8E24AA',
                '#FB8C00'

            ]

        }]

    },

    options: {

        responsive: true,

        maintainAspectRatio: false,

        plugins: {

            legend: {

                display: false

            }

        },

        scales: {

            y: {

                beginAtZero: true,

                ticks: {

                    precision: 0

                }

            }

        }

    }

});

    </script>

}