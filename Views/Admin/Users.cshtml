@model IEnumerable<SavourSA_Project.Models.ApplicationUser>

@{
    ViewBag.Title = "User Management";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<h2>User Management</h2>

<p class="text-muted">
    View and manage registered members.
</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">

        @TempData["Success"]

    </div>
}

@using (Html.BeginForm("Users", "Admin", FormMethod.Get))
{
    <div class="row mb-4">

        <div class="col-md-5">

            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Search users..." />

        </div>

        <div class="col-md-2">

            <button class="btn btn-success">

                <i class="fa fa-search"></i>

                Search

            </button>

        </div>

    </div>
}

@if (!Model.Any())
{

    <div class="alert alert-warning">

        No registered users found.

    </div>

}
else
{

    <table class="table table-bordered table-hover">

        <thead>

            <tr>

                <th>Name</th>

                <th>Email</th>

                <th>Province</th>

                <th>Joined</th>

                <th width="160">Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var user in Model)
            {

                <tr>

                    <td>@user.FirstName @user.LastName</td>

                    <td>@user.Email</td>

                    <td>@user.Province</td>

                    <td>@user.CreatedAt.ToShortDateString()</td>

                    <td>

                        <a href="@Url.Action("ViewUser","Admin",new{id=user.Id})"
                           class="btn btn-info btn-sm">

                            <i class="fa fa-eye"></i>

                        </a>

                        <a href="@Url.Action("DeleteUser","Admin",new{id=user.Id})"
                           class="btn btn-danger btn-sm">

                            <i class="fa fa-trash"></i>

                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

}