@model IEnumerable<SavourSA_Project.Models.Recipe>

@{
    ViewBag.Title = "Recipe Management";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 style="font-weight:700;">Recipe Management</h2>

        <p class="text-muted">
            Manage recipes submitted by community members.
        </p>

    </div>

</div>

<div class="alert alert-info">

    <i class="fa fa-info-circle"></i>

    Recipes are submitted by registered members. Administrators can review, edit and remove recipes from this page.

</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">

        @TempData["Success"]

    </div>
}

@using (Html.BeginForm("Recipes", "Admin", FormMethod.Get))
{
    <div class="row mb-4">

        <div class="col-md-5">

            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Search recipe title..." />

        </div>

        <div class="col-md-3">

            <button class="btn btn-success">

                <i class="fa fa-search"></i>

                Search

            </button>

        </div>

    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">

        <h4>No Recipes Found</h4>

        <p>
            No recipes have been submitted yet.
        </p>

    </div>
}
else
{

    <table class="table table-bordered table-hover">

        <thead class="thead-dark">

            <tr>

                <th>Image</th>

                <th>Recipe</th>

                <th>Category</th>

                <th>Author</th>

                <th>Date Created</th>

                <th width="180">Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var recipe in Model)
            {

                <tr>

                    <td width="100">

                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <img src="@Url.Content(recipe.ImageUrl)"
                                 style="width:80px;height:80px;object-fit:cover;border-radius:8px;" />
                        }
                        else
                        {
                            <img src="~/Content/Images/Recipes/default-recipe.jpg"
                                 style="width:80px;height:80px;object-fit:cover;border-radius:8px;" />
                        }

                    </td>

                    <td>

                        <strong>@recipe.Title</strong>

                    </td>

                    <td>

                        @(recipe.Category != null ? recipe.Category.Name : "No Category")

                    </td>

                    <td>

                        @(recipe.User != null ? recipe.User.FirstName + " " + recipe.User.LastName : "Unknown")

                    </td>

                    <td>

                        @recipe.DateCreated.ToShortDateString()

                    </td>

                    <td>

                        <a href="@Url.Action("ViewRecipe","Admin",new{id=recipe.RecipeId})"
                           class="btn btn-info btn-sm">

                            <i class="fa fa-eye"></i>

                        </a>

                        <a href="@Url.Action("EditRecipe","Admin",new{id=recipe.RecipeId})"
                           class="btn btn-warning btn-sm">

                            <i class="fa fa-pencil"></i>

                        </a>

                        <a href="@Url.Action("DeleteRecipe","Admin",new{id=recipe.RecipeId})"
                           class="btn btn-danger btn-sm">

                            <i class="fa fa-trash"></i>

                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

}
