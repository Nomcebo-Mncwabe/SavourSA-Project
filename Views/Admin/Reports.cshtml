@model SavourSA_Project.Models.ViewModels.DashboardViewModel

@{
    ViewBag.Title = "Reports";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="row">

    <div class="col-md-8">

        <h2 style="font-weight:bold;">Reports & Analytics</h2>

        <p class="text-muted">
            Monitor recipes, members and platform activity.
        </p>

    </div>

    <div class="col-md-4 text-right">

        <a href="@Url.Action("DownloadReport","Admin")"
           class="btn btn-success btn-lg">

            <i class="fa fa-download"></i>

            Download Report

        </a>

    </div>

</div>

<hr />

<div class="row">

    <div class="col-md-3">

        <div class="report-card">

            <h2>@Model.TotalRecipes</h2>

            <p>Total Recipes</p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="report-card">

            <h2>@Model.TotalUsers</h2>

            <p>Members</p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="report-card">

            <h2>@Model.TotalFavourites</h2>

            <p>Favourites</p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="report-card">

            <h2>@Model.TotalCategories</h2>

            <p>Categories</p>

        </div>

    </div>

</div>

<br />

<div class="row">

    <div class="col-md-6">

        <div class="analytics-card">

            <h3>Recipes by Category</h3>

            <hr />

            @if (Model.CategorySummary.Any())
            {

                <table class="table table-bordered table-hover">

                    <thead>

                        <tr>

                            <th>Category</th>

                            <th>Total Recipes</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.CategorySummary)
                        {

                            <tr>

                                <td>@item.CategoryName</td>

                                <td>@item.RecipeCount</td>

                            </tr>

                        }

                    </tbody>

                </table>

            }
            else
            {

                <div class="alert alert-info">

                    No category information available.

                </div>

            }

        </div>

    </div>

    <div class="col-md-6">

        <div class="analytics-card">

            <h3>System Summary</h3>

            <hr />

            <table class="table table-striped">

                <tr>

                    <th>Total Members</th>

                    <td>@Model.TotalUsers</td>

                </tr>

                <tr>

                    <th>Total Recipes</th>

                    <td>@Model.TotalRecipes</td>

                </tr>

                <tr>

                    <th>Total Categories</th>

                    <td>@Model.TotalCategories</td>

                </tr>

                <tr>

                    <th>Total Favourites</th>

                    <td>@Model.TotalFavourites</td>

                </tr>

            </table>

        </div>

    </div>

</div>

<br />

<div class="row">

    <div class="col-md-6">

        <div class="analytics-card">

            <h3>Latest Members</h3>

            <hr />

            @if (Model.LatestUsers.Any())
            {

                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Name</th>

                            <th>Email</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var user in Model.LatestUsers)
                        {

                            <tr>

                                <td>

                                    @user.FirstName @user.LastName

                                </td>

                                <td>

                                    @user.Email

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            }
            else
            {

                <div class="alert alert-warning">

                    No registered users.

                </div>

            }

        </div>

    </div>

    <div class="col-md-6">

        <div class="analytics-card">

            <h3>Latest Recipes</h3>

            <hr />

            @if (Model.LatestRecipes.Any())
            {

                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Recipe</th>

                            <th>Date</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var recipe in Model.LatestRecipes)
                        {

                            <tr>

                                <td>@recipe.Title</td>

                                <td>@recipe.DateCreated.ToShortDateString()</td>

                            </tr>

                        }

                    </tbody>

                </table>

            }
            else
            {

                <div class="alert alert-warning">

                    No recipes have been uploaded yet.

                </div>

            }

        </div>

    </div>

</div>

@section scripts{

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        // Chart.js integration with live database data
        // will be added once your project has
        // real users and recipes.

    </script>

}