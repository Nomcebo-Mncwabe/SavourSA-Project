
<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width" />

    <title>@ViewBag.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet" />

    <link href="~/Content/admin.css" rel="stylesheet" />

</head>

<body>

    <div class="wrapper">

        <!-- Sidebar -->

        <div class="sidebar">

            <h2 class="logo">🍽️ SavourSA</h2>

            <hr />

            <ul>

                <li>@Html.ActionLink(" Dashboard", "Dashboard", "Admin")</li>

                <li>@Html.ActionLink(" Recipes", "Recipes", "Admin")</li>

                <li>@Html.ActionLink(" Categories", "Categories", "Admin")</li>

                <li>@Html.ActionLink(" Users", "Users", "Admin")</li>

                <li>@Html.ActionLink(" Reports", "Reports", "Admin")</li>

                <li>@Html.ActionLink(" Comments", "Comments", "Admin")</li>

                <li>@Html.ActionLink(" Settings", "Settings", "Admin")</li>

            </ul>

        </div>

        <!-- Main Content -->

        <div class="main-content">

            <!-- Top Navbar -->

            <div class="topbar">

                <h4>@ViewBag.Title</h4>

                <div>

                    <span>Welcome, Admin 👋</span>

                </div>

            </div>

            @RenderBody()

        </div>

    </div>

</body>

</html>

