
<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewBag.Title - SavourSA Admin</title>

    @Styles.Render("~/Content/css")

    <link href="~/Content/admin.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          rel="stylesheet" />

    @Scripts.Render("~/bundles/modernizr")

</head>

<body>

    <div class="wrapper">

        <!-- SIDEBAR -->

        <aside class="sidebar">

            <div class="logo">

                🍽️ SavourSA

            </div>

            <p>
                Admin Panel
            </p>

            <ul>

                <li>

                    <a href="@Url.Action("Dashboard","Admin")">

                        <i class="fa fa-home"></i>

                        Dashboard

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Recipes","Admin")">

                        <i class="fas fa-utensils"></i>

                        <span>Recipes</span>

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Categories","Admin")">

                        <i class="fas fa-layer-group"></i>

                        <span>Categories</span>

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Users","Admin")">

                        <i class="fas fa-users"></i>

                        <span>Users</span>

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Reports","Admin")">

                        <i class="fas fa-chart-line"></i>

                        <span>Reports</span>

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Comments","Admin")">

                        <i class="fas fa-comments"></i>

                        <span>Comments</span>

                    </a>

                </li>

                <li>

                    <a href="@Url.Action("Settings","Admin")">

                        <i class="fas fa-cog"></i>

                        <span>Settings</span>

                    </a>

                </li>

            </ul>

            <div class="logout-section">

                <a href="#"
                   class="logout-btn">

                    <i class="fa fa-sign-out"></i>

                    Logout

                </a>

            </div>

        </aside>

        <!-- MAIN -->

        <main class="main-content">

            <!-- TOP BAR -->

            <div class="topbar">

                <div>

                    <h3>@ViewBag.Title</h3>

                    <small style="color:#777;">
                        SavourSA Administration System
                    </small>

                </div>

                <div style="display:flex;align-items:center;gap:20px;">

                    <i class="fas fa-bell fa-lg"></i>

                    <img src="https://ui-avatars.com/api/?name=Admin&background=43A047&color=fff&size=64"
                         style="width:45px;height:45px;border-radius:50%;" />

                    <div>

                        <strong>Administrator</strong>

                        <br />

                        <small style="color:#888;">
                            Online
                        </small>

                    </div>

                </div>

            </div>

            @RenderBody()

        </main>

    </div>

    @Scripts.Render("~/bundles/jquery")

    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("scripts", required: false)

</body>

</html>