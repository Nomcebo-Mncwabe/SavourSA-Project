@model SavourSA_Project.Models.Recipe

@{
    ViewBag.Title = Model.Title;
}

<div class="container" style="padding:40px 15px; max-width:800px;">
    <h1>@Model.Title</h1>
    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/Content/images/recipe-placeholder.jpg" : Model.ImageUrl)"
         class="img-responsive" style="width:100%; max-height:400px; object-fit:cover; margin-bottom:20px;" />

    <p class="lead">@Model.ShortDescription</p>

    @if (Request.IsAuthenticated)
    {
        <h3>Ingredients</h3>
        <p>@Model.Ingredients</p>

        <h3>Instructions</h3>
        <p>@Model.Instructions</p>
    }
    else
    {
        <div class="well text-center" style="margin-top:30px;">
            <h3>🔒 Full recipe locked</h3>
            <p>Sign up or log in to see the full ingredients list and step-by-step instructions.</p>
            @Html.ActionLink("Login", "Login", "Account", null, new { @class = "btn btn-warning", style = "margin:5px;" })
            @Html.ActionLink("Sign Up", "Register", "Account", null, new { @class = "btn btn-default", style = "margin:5px;" })
        </div>
    }
</div>